{
  "extends": "@system/typescript/nest.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@data/config": [
        "../../packages/data/config/src"
      ],
      "@data/decorators": [
        "../../packages/data/decorators/src"
      ],
      "@data/domain": [
        "../../packages/data/domain/src"
      ],
      "@data/domain/*": [
